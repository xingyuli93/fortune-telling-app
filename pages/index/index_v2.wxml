<!--index.wxml-->
<view class="container">
  <!-- 主输入界面 -->
  <view class="main-content" hidden="{{showResult || showShake}}">
    <view class="title">请输入您的信息</view>
    <view class="form">
      <input class="input-item" placeholder="请输入您的姓名" bindinput="onNameInput"/>
      <picker mode="date" class="input-item picker" bindchange="onBirthdateChange">
        <view>{{birthdate || '请选择您的生日'}}</view>
      </picker>
      <picker class="input-item picker" bindchange="onMbtiChange" range="{{mbtiRange}}">
        <view>{{mbtiRange[mbtiIndex] || '请选择您的MBTI类型'}}</view>
      </picker>
    </view>
    <button class="shake-button" bindtap="startShake">开始摇签</button>
  </view>

  <!-- 摇签动画界面 -->
  <view class="shake-container" hidden="{{!showShake}}">
    <image 
      class="shake-bucket {{isShaking ? 'shaking' : ''}}" 
      src="https://image.freepik.com/free-vector/chinese-fortune-sticks-in-bamboo-holder_1308-102358.jpg"
    />
    <image 
      class="shake-stick {{isStickFalling ? 'falling' : ''}}" 
      src="https://image.freepik.com/free-vector/fortune-stick-illustration_1308-102357.jpg"
    />
    <view class="shake-tip">请摇晃您的手机</view>
  </view>

  <!-- 结果卡片 -->
  <view class="result-card" hidden="{{!showResult}}" style="animation: fadeInScale 0.5s forwards;">
    <view class="result-fortune">{{result.fortune}}</view>
    <view class="result-analysis">
      <view class="analysis-item">{{analysisWithTyping.summary}}</view>
      <view class="analysis-item">{{analysisWithTyping.study}}</view>
      <view class="analysis-item">{{analysisWithTyping.career}}</view>
      <view class="analysis-item">{{analysisWithTyping.love}}</view>
      <view class="analysis-item">{{analysisWithTyping.health}}</view>
      <view class="analysis-item">{{analysisWithTyping.wealth}}</view>
      <view class="analysis-item">{{analysisWithTyping.social}}</view>
    </view>
    <button class="close-button" bindtap="closeResult">重新算命</button>
  </view>
</view>
