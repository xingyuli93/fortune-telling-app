.shake-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  width: 100%;
  position: relative;
}

.shake-bucket {
  width: 300rpx;
  height: 300rpx;
  z-index: 2;
}

.shaking {
  animation: shake-animation 0.2s linear infinite;
}

@keyframes shake-animation {
  0% { transform: translate(0, 0) rotate(0deg); }
  25% { transform: translate(5rpx, -5rpx) rotate(1deg); }
  50% { transform: translate(0, 0) rotate(0eg); }
  75% { transform: translate(-5rpx, 5rpx) rotate(-1deg); }
  100% { transform: translate(0, 0) rotate(0deg); }
}

.shake-stick {
  width: 200rpx;
  height: 200rpx; /* 调整为合适尺寸 */
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(45deg);
  z-index: 1;
  opacity: 0;
  transition: all 0.5s ease-in-out;
}

.falling {
  top: 60%;
  opacity: 1;
  transform: translate(-50%, -50%) rotate(90deg);
}

.shake-tip {
  margin-top: 40rpx;
  font-size: 32rpx;
  color: #fff;
  text-shadow: 0 0 5px rgba(0,0,0,0.5);
}

