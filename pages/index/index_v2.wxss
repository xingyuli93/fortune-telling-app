.shake-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  width: 100%;
  position: relative;
}

.shake-wrapper {
  perspective: 1000rpx;
}

.shake-bucket {
  width: 350rpx;
  height: 350rpx;
  z-index: 2;
  transition: transform 0.2s ease-in-out;
}

.shaking .shake-bucket {
  animation: shake-3d 0.4s linear infinite;
}

@keyframes shake-3d {
  0% { transform: translate(0, 0) rotateX(0) rotateY(0); }
  25% { transform: translate(5rpx, -5rpx) rotateX(-5deg) rotateY(5deg); }
  50% { transform: translate(0, 0) rotateX(0) rotateY(0); }
  75% { transform: translate(-5rpx, 5rpx) rotateX(5deg) rotateY(-5deg); }
  100% { transform: translate(0, 0) rotateX(0) rotateY(0); }
}

.shake-stick {
  width: 250rpx;
  height: 250rpx;
  position: absolute;
  top: 35%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(45deg);
  z-index: 1;
  opacity: 0;
  transition: all 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55);
}

.falling {
  top: 65%;
  opacity: 1;
  transform: translate(-50%, -50%) rotate(100deg);
}

.shake-tip {
  margin-top: 60rpx;
  font-size: 36rpx;
  color: #f0ad4e;
  text-shadow: 0 0 10px rgba(240, 173, 78, 0.7);
  animation: breath 2s ease-in-out infinite;
}

@keyframes breath {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}

