page {
  height: 100%;
}

.container {
  height: 100%;
  background-image: url('https://images.unsplash.com/photo-1534796636912-3b95b3ab5986?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2071&q=80');
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  color: white;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.main-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 40rpx;
  border-radius: 20rpx;
  transition: opacity 0.5s;
}

.title {
  font-size: 48rpx;
  margin-bottom: 60rpx;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
}

.form {
  width: 100%;
  margin-bottom: 40rpx;
}

.input-item {
  width: 100%;
  padding: 25rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 15rpx;
  font-size: 32rpx;
  background-color: rgba(255, 255, 255, 0.1);
  color: white;
  box-sizing: border-box;
}

.picker {
  line-height: normal;
  padding: 25rpx; /* 保持和input一样的padding */
}

.shake-button {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  background: linear-gradient(45deg, #f0ad4e, #ec971f);
  color: white;
  border: none;
  border-radius: 15rpx;
  font-size: 36rpx;
  font-weight: bold;
}

.result-card {
  width: 100%;
  padding: 40rpx;
  background-color: rgba(0, 0, 0, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
  text-align: center;
  opacity: 0;
  box-sizing: border-box;
}

@keyframes fadeInScale {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.result-fortune {
  font-size: 40rpx;
  margin-bottom: 30rpx;
  color: #f0ad4e;
  font-weight: bold;
}

.result-analysis {
  text-align: left;
}

.analysis-item {
  font-size: 32rpx;
  line-height: 1.8;
  margin-bottom: 25rpx;
  white-space: pre-wrap; /* 保证换行符生效 */
}

.close-button {
  margin-top: 30rpx;
  padding: 15rpx 30rpx;
  background-color: transparent;
  border: 1rpx solid #f0ad4e;
  color: #f0ad4e;
  border-radius: 10rpx;
}
